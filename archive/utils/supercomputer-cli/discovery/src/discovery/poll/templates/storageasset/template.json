{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "outLocation": {
            "type": "String"
        },
        "outStorageContainerName": {
            "type": "String"
        },
        "outStorageAssetName": {
            "type": "String"
        },
        "outApiVersion": {
            "defaultValue": "2026-02-01-preview",
            "type": "String"
        },
        "outStorageAssetDescription": {
            "type": "String"
        },
        "outStorageAssetPath": {
            "type": "String"
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Discovery/storagecontainers/storageassets",
            "apiVersion": "[parameters('outApiVersion')]",
            "name": "[concat(parameters('outStorageContainerName'), '/', parameters('outStorageAssetName'))]",
            "location": "[parameters('outLocation')]",
            "dependsOn": [],
            "properties": {
                "description": "[parameters('outStorageAssetDescription')]",
                "path": "[parameters('outStorageAssetPath')]"
            }
        }
    ]
}
