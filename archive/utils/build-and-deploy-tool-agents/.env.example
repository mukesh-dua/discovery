# Example Environment Variables for Tool Image Builder
# Copy this file to .env and fill in your Azure details
# The script will use these values if set, otherwise it will prompt interactively

# Azure Container Registry name (required)
# Example: ACR_NAME=mydiscoveryacr
ACR_NAME=

# Azure Resource Group containing the ACR (required)
# Example: AZURE_RESOURCE_GROUP=discovery-rg
AZURE_RESOURCE_GROUP=

# Azure Subscription ID (optional - uses default if not set)
# Example: AZURE_SUBSCRIPTION_ID=12345678-1234-1234-1234-123456789012
AZURE_SUBSCRIPTION_ID=

# Note: You must be authenticated with Azure CLI before running the script
# Run: az login
