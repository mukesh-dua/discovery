&CONTROL
    calculation = 'bands'
    prefix = 'silicon'
    outdir = './tmp'
    pseudo_dir = '/opt/apps/qe/7.3/pseudo'
    verbosity = 'high'
/

&SYSTEM
    ibrav = 2
    celldm(1) = 10.2
    nat = 2
    ntyp = 1
    ecutwfc = 30.0
    ecutrho = 240.0
    nbnd = 8
/

&ELECTRONS
    conv_thr = 1.0d-8
/

ATOMIC_SPECIES
Si  28.086  Si.pbe-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS {alat}
Si  0.00  0.00  0.00
Si  0.25  0.25  0.25

K_POINTS {crystal_b}
5
0.500  0.500  0.500  20  ! L
0.000  0.000  0.000  20  ! Gamma
0.500  0.000  0.500  20  ! X
0.500  0.250  0.750  20  ! W
0.500  0.500  0.500  1   ! L
